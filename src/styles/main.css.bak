/* ============================================================
   Velura — Design System & Layout
   ============================================================ */

:root {
  --cream: #E8F4FF;
  --ink: #2A2522;
  --muted: #6B635D;
  --soft: #8C857E;
  --terracotta: #C97B63;
  --terracotta-h: #b36a53;
  --brown: #7D562D;
  --brown-light: #D4A3A3;
  --tab-bg: #F4E4DC;
  --field-bg: #F3F3F5;
  --line: #E8DFD6;
  --facebook: #8AACF5;
  --facebook-h: #7296e0;
  --checkout-bg: #FDFAF8;
  --card-border: rgba(130, 116, 115, 0.2);
  --text-secondary: #827473;
  --text-dark: #1A1A1A;
  --text-body: #504444;
  --success-bg: #F7F3F2;
  --error: #D4183D;
  --max-w: 1200px;
  --header-h: auto;
  --radius-sm: 4px;
  --radius-md: 8px;
  --radius-lg: 16px;
  --shadow-card: 0 4px 6px -4px rgba(0, 0, 0, 0.1), 0 10px 15px -3px rgba(0, 0, 0, 0.1);
  --stage-w: 1172px;
  --stage-h: 715px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  font-family: "DM Sans", system-ui, -apple-system, "Segoe UI", sans-serif;
  color: var(--ink);
  background: #fff;
  line-height: 1.5;
  min-height: 100vh;
}

img { max-width: 100%; height: auto; display: block; }

a { color: inherit; text-decoration: none; }

button, input, textarea, select {
  font: inherit;
  color: inherit;
}

ul { list-style: none; }

.container {
  width: 100%;
  max-width: var(--max-w);
  margin: 0 auto;
  padding: 0 24px;
}

/* ---------- Typography ---------- */
.font-display {
  font-family: "Playfair Display", Georgia, serif;
}

.page-title {
  font-family: "Playfair Display", Georgia, serif;
  font-size: clamp(1.5rem, 4vw, 1.875rem);
  font-weight: 500;
  color: var(--text-dark);
  line-height: 1.2;
}

.section-title {
  font-family: "Playfair Display", Georgia, serif;
  font-size: 1.25rem;
  font-weight: 500;
  color: var(--text-dark);
}

.label-upper {
  font-size: 0.75rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: #50453B;
}

/* ---------- Header ---------- */
.site-header {
  border-bottom: 1px solid var(--line);
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.site-header__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 16px 0;
  border-bottom: 1px solid var(--line);
}

.site-header__logo img {
  width: 84px;
  height: auto;
}

.site-header__search {
  flex: 1;
  max-width: 448px;
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 16px;
  background: var(--tab-bg);
  border: 1px solid var(--line);
  border-radius: var(--radius-sm);
  color: var(--muted);
  font-size: 0.875rem;
  font-weight: 500;
}

.site-header__search input {
  flex: 1;
  border: none;
  background: transparent;
  outline: none;
  min-width: 0;
}

.site-header__actions {
  display: flex;
  align-items: center;
  gap: 8px;
}

.icon-btn {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border: none;
  background: transparent;
  cursor: pointer;
  border-radius: var(--radius-sm);
  transition: background 0.2s;
}

.icon-btn:hover { background: var(--tab-bg); }

.cart-badge {
  position: absolute;
  top: -2px;
  right: -2px;
  min-width: 20px;
  height: 20px;
  padding: 0 4px;
  background: var(--terracotta);
  color: #fff;
  font-size: 0.75rem;
  font-weight: 500;
  border-radius: 999px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.site-header__nav {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8px 32px;
  padding: 16px 0;
}

.site-header__nav a {
  font-size: 0.875rem;
  color: var(--soft);
  font-weight: 400;
  transition: color 0.2s;
}

.site-header__nav a:hover,
.site-header__nav a.is-active {
  color: var(--ink);
  font-weight: 500;
}

.menu-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  border: none;
  background: none;
  cursor: pointer;
  padding: 8px;
}

.menu-toggle span {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--ink);
  border-radius: 1px;
}

/* ---------- Footer ---------- */
.site-footer {
  border-top: 1px solid var(--line);
  background: #fff;
  margin-top: auto;
}

.site-footer__inner {
  padding: 48px 0;
}

.site-footer__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 32px;
}

.site-footer__brand .font-display {
  font-size: 1.5rem;
  font-weight: 500;
}

.site-footer__brand p {
  margin-top: 16px;
  color: var(--muted);
  font-size: 0.875rem;
  line-height: 1.6;
}

.site-footer__social {
  display: flex;
  gap: 12px;
  margin-top: 16px;
}

.site-footer__social a {
  width: 32px;
  height: 32px;
  background: var(--tab-bg);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.site-footer h4 {
  font-size: 0.875rem;
  font-weight: 500;
  margin-bottom: 16px;
}

.site-footer ul li + li { margin-top: 8px; }

.site-footer ul a {
  font-size: 0.875rem;
  color: var(--muted);
  font-weight: 500;
  transition: color 0.2s;
}

.site-footer ul a:hover { color: var(--terracotta); }

.site-footer__contact li {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  font-size: 0.875rem;
  color: var(--muted);
}

.site-footer__contact li + li { margin-top: 12px; }

.site-footer__bottom {
  padding-top: 32px;
  margin-top: 32px;
  border-top: 1px solid var(--line);
  text-align: center;
  color: var(--muted);
  font-size: 0.875rem;
}

/* ---------- Checkout layout ---------- */
.checkout-page {
  background: var(--checkout-bg);
  min-height: calc(100vh - 200px);
  padding: 32px 0 64px;
}

.breadcrumb {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8px;
  font-size: 0.875rem;
  color: var(--text-secondary);
  margin-bottom: 32px;
}

.breadcrumb a:hover { color: var(--terracotta); }

.breadcrumb__current { color: var(--text-body); }

.checkout-steps {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  gap: 12px 16px;
  margin-bottom: 40px;
}

.checkout-step {
  display: flex;
  align-items: center;
  gap: 12px;
}

.checkout-step__num {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.875rem;
  font-weight: 600;
  flex-shrink: 0;
}

.checkout-step__num--done {
  background: #E8C9BE;
  color: #fff;
}

.checkout-step__num--active {
  background: #D4A3A3;
  color: #fff;
}

.checkout-step__num--pending {
  background: var(--checkout-bg);
  color: var(--text-secondary);
  border: 1px solid var(--card-border);
}

.checkout-step__num--confirm {
  background: #CCCCCC;
  color: #fff;
}

.checkout-step__label {
  font-size: 0.875rem;
  white-space: nowrap;
}

.checkout-step__label--active {
  color: var(--terracotta);
  font-weight: 600;
}

.checkout-step__label--done {
  color: var(--terracotta);
  font-weight: 600;
}

.checkout-step__label--pending {
  color: var(--text-secondary);
}

.checkout-step__line {
  width: 48px;
  height: 2px;
  background: rgba(130, 116, 115, 0.2);
  flex-shrink: 0;
}

.checkout-step__line--done { background: #7C5454; }

.checkout-grid {
  display: grid;
  grid-template-columns: 1fr 360px;
  gap: 32px;
  align-items: start;
}

.checkout-main { min-width: 0; }

.card {
  background: #fff;
  border: 1px solid var(--card-border);
  border-radius: var(--radius-sm);
  padding: 24px;
}

.card + .card { margin-top: 24px; }

.card__header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 24px;
}

.card__header svg { flex-shrink: 0; color: #7C5454; }

/* ---------- Form elements ---------- */
.form-group { margin-bottom: 16px; }

.form-group label {
  display: block;
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--text-body);
  margin-bottom: 8px;
}

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.form-input,
.form-textarea {
  width: 100%;
  padding: 12px 16px;
  background: #fff;
  border: 1px solid var(--card-border);
  border-radius: var(--radius-sm);
  font-size: 0.875rem;
  transition: border-color 0.2s;
}

.form-input:focus,
.form-textarea:focus {
  outline: none;
  border-color: var(--terracotta);
}

.form-textarea {
  min-height: 86px;
  resize: vertical;
}

.form-input::placeholder,
.form-textarea::placeholder {
  color: rgba(26, 26, 26, 0.5);
}

/* ---------- Address cards ---------- */
.address-list { display: flex; flex-direction: column; gap: 16px; }

.address-card {
  position: relative;
  padding: 16px;
  border-radius: 12px;
  cursor: pointer;
  transition: border-color 0.2s, background 0.2s;
}

.address-card input { position: absolute; opacity: 0; pointer-events: none; }

.address-card--default {
  background: #FDF8F8;
  border: 2px solid var(--brown);
}

.address-card--secondary {
  background: rgba(255, 255, 255, 0.5);
  border: 1px solid rgba(212, 196, 183, 0.5);
}

.address-card.is-selected {
  border-color: var(--brown);
  background: #FDF8F8;
}

.address-card__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 8px;
}

.address-card__name {
  font-size: 1rem;
  font-weight: 700;
  color: #1C1B1B;
}

.address-card__badge {
  padding: 2px 8px;
  background: var(--brown);
  color: #fff;
  font-size: 0.625rem;
  text-transform: uppercase;
  border-radius: 999px;
}

.address-card__phone,
.address-card__addr {
  font-size: 0.875rem;
  color: #50453B;
  line-height: 1.4;
}

.address-card__check {
  position: absolute;
  top: 12px;
  right: 12px;
}

.btn-add-address {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  border: none;
  background: none;
  color: var(--brown);
  font-size: 0.75rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  cursor: pointer;
  margin-top: 8px;
}

/* ---------- Radio option cards ---------- */
.option-list { display: flex; flex-direction: column; gap: 12px; }

.option-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 16px;
  border: 1px solid var(--card-border);
  border-radius: var(--radius-sm);
  cursor: pointer;
  transition: background 0.2s, border-color 0.2s;
}

.option-card input { display: none; }

.option-card.is-selected,
.option-card:has(input:checked) {
  background: #E8C9BE;
  border-color: #7C5454;
}

.option-card__left {
  display: flex;
  align-items: center;
  gap: 12px;
}

.option-card__radio {
  width: 20px;
  height: 20px;
  border: 2px solid var(--card-border);
  border-radius: 50%;
  flex-shrink: 0;
  position: relative;
}

.option-card.is-selected .option-card__radio,
.option-card:has(input:checked) .option-card__radio {
  border-color: var(--brown);
}

.option-card.is-selected .option-card__radio::after,
.option-card:has(input:checked) .option-card__radio::after {
  content: "";
  position: absolute;
  inset: 3px;
  background: var(--brown);
  border-radius: 50%;
}

.option-card__title {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--text-dark);
}

.option-card__desc {
  font-size: 0.75rem;
  color: var(--text-secondary);
  margin-top: 4px;
}

.option-card__price {
  font-size: 0.875rem;
  font-weight: 600;
  color: #7C5454;
  white-space: nowrap;
}

/* ---------- Order summary sidebar ---------- */
.order-summary {
  background: #fff;
  border: 1px solid var(--line);
  border-radius: var(--radius-lg);
  padding: 24px;
  position: sticky;
  top: 120px;
}

.order-summary__title {
  font-family: "Playfair Display", Georgia, serif;
  font-size: 1.5rem;
  font-weight: 500;
  margin-bottom: 20px;
}

.coupon-row {
  display: flex;
  gap: 8px;
  margin-bottom: 20px;
}

.coupon-row .form-input {
  flex: 1;
  background: var(--field-bg);
  border-color: var(--line);
  border-radius: 10px;
}

.btn-outline {
  padding: 12px 24px;
  border: 1px solid var(--line);
  border-radius: var(--radius-md);
  background: #fff;
  color: var(--terracotta);
  font-weight: 500;
  font-size: 0.875rem;
  cursor: pointer;
  white-space: nowrap;
  transition: background 0.2s;
}

.btn-outline:hover { background: var(--tab-bg); }

.summary-lines {
  padding: 16px 0;
  border-top: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
}

.summary-line {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 0.875rem;
  color: var(--muted);
}

.summary-line + .summary-line { margin-top: 12px; }

.summary-line__value { color: var(--ink); }

.summary-line--shipping .summary-line__value { color: #A8B5A0; }

.summary-total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 0;
}

.summary-total__label {
  font-size: 1rem;
  color: var(--ink);
}

.summary-total__value {
  font-family: "Playfair Display", Georgia, serif;
  font-size: 1.75rem;
  color: var(--terracotta);
}

.summary-note {
  text-align: center;
  font-size: 0.75rem;
  color: var(--muted);
  padding-top: 16px;
}

/* ---------- Buttons ---------- */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  border: none;
  cursor: pointer;
  font-weight: 500;
  transition: background 0.2s, opacity 0.2s;
}

.btn--primary {
  padding: 14px 32px;
  background: var(--brown-light);
  color: #fff;
  border-radius: var(--radius-sm);
  font-size: 0.875rem;
  text-transform: uppercase;
  letter-spacing: 0.025em;
}

.btn--primary:hover { background: var(--terracotta-h); }

.btn--accent {
  padding: 14px 32px;
  background: var(--terracotta);
  color: #fff;
  border-radius: var(--radius-md);
  font-size: 1rem;
}

.btn--accent:hover { background: var(--terracotta-h); }

.btn--brown {
  padding: 17px 80px;
  background: var(--brown);
  color: #fff;
  border-radius: 6px;
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.btn--brown-outline {
  padding: 16px 80px;
  background: transparent;
  color: var(--brown);
  border: 1px solid var(--brown);
  border-radius: 6px;
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.btn--full { width: 100%; }

.checkout-actions {
  display: flex;
  justify-content: flex-end;
  gap: 12px;
  margin-top: 24px;
}

/* ---------- Sign in page ---------- */
body.page-signin {
  background: var(--cream);
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  overflow-x: hidden;
}

.signin-stage {
  position: relative;
  width: min(var(--stage-w), 100vw);
  height: min(var(--stage-h), calc(100vh - 48px));
  background: var(--cream);
  overflow: hidden;
}

.signin-stage .bg-texture {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  opacity: 0.15;
  object-fit: cover;
  pointer-events: none;
}

.signin-stage .product {
  position: absolute;
  pointer-events: none;
  user-select: none;
}

.signin-stage .product--8 { left: -1.9%; top: 1%; width: 105.7%; height: auto; }
.signin-stage .product--3 { left: 2.8%; top: 20.3%; width: 23.8%; }
.signin-stage .product--6 { left: 75.7%; top: -3.2%; width: 24.3%; }
.signin-stage .product--1 { left: -6.7%; top: 32.3%; width: 28%; }
.signin-stage .product--5 { left: 77.7%; top: 32.3%; width: 31.5%; }
.signin-stage .product--4 { left: 67.3%; top: 29.9%; width: 23.8%; }

.signin-stage .brand-logo {
  position: absolute;
  left: 0;
  top: 0;
  width: 134px;
  z-index: 2;
}

.login-card {
  position: absolute;
  left: 50%;
  top: 12px;
  transform: translateX(-50%);
  width: min(448px, calc(100% - 32px));
  padding: 32px;
  background: #fff;
  border-radius: var(--radius-lg);
  border: 1px solid var(--line);
  box-shadow: var(--shadow-card);
  z-index: 5;
}

.login-card__head { text-align: center; }

.login-card__title {
  font-family: "Playfair Display", Georgia, serif;
  font-size: 2rem;
  font-weight: 500;
  line-height: 1.5;
}

.login-card__subtitle {
  margin-top: 8px;
  font-size: 0.875rem;
  color: var(--muted);
}

.tabs {
  display: flex;
  gap: 4px;
  margin-top: 32px;
  padding: 4px;
  background: var(--tab-bg);
  border-radius: 10px;
}

.tab {
  flex: 1;
  height: 36px;
  border: none;
  border-radius: 4px;
  background: transparent;
  font-size: 0.875rem;
  color: var(--soft);
  cursor: pointer;
  transition: background 0.2s, color 0.2s;
}

.tab--active {
  background: #fff;
  color: var(--terracotta);
  font-weight: 500;
}

.fields { margin-top: 24px; }

.field { margin-top: 16px; }

.field:first-child { margin-top: 0; }

.field__label {
  display: block;
  font-size: 0.875rem;
  font-weight: 500;
  margin-bottom: 8px;
}

.field__control { position: relative; }

.field__input {
  width: 100%;
  height: 46px;
  padding: 0 16px;
  background: var(--field-bg);
  border: 1px solid var(--line);
  border-radius: 10px;
  font-size: 0.875rem;
  transition: border-color 0.2s;
}

.field__input:focus {
  outline: none;
  border-color: var(--terracotta);
  background: #fff;
}

.field--password .field__input { padding-right: 44px; }

.field__toggle {
  position: absolute;
  right: 16px;
  top: 50%;
  transform: translateY(-50%);
  border: none;
  background: none;
  cursor: pointer;
  padding: 0;
  display: flex;
}

.options {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16px;
  font-size: 0.875rem;
}

.remember {
  display: flex;
  align-items: center;
  gap: 8px;
  color: var(--soft);
  cursor: pointer;
}

.remember input { accent-color: var(--terracotta); }

.forgot { color: var(--terracotta); font-weight: 500; }

.forgot:hover { text-decoration: underline; }

.btn--login {
  width: 100%;
  height: 52px;
  margin-top: 24px;
  background: var(--terracotta);
  color: #fff;
  border-radius: var(--radius-md);
  font-size: 1rem;
}

.btn--login:hover { background: var(--terracotta-h); }

.oauth {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12px;
  margin-top: 10px;
}

.btn--facebook {
  flex: 1;
  min-width: 140px;
  height: 48px;
  background: var(--facebook);
  color: #fff;
  border-radius: var(--radius-sm);
  font-size: 0.875rem;
}

.btn--facebook:hover { background: var(--facebook-h); }

.btn--guest {
  flex: 1;
  min-width: 140px;
  height: 48px;
  background: var(--terracotta);
  color: #fff;
  border-radius: var(--radius-sm);
  font-size: 0.875rem;
}

.signup {
  margin-top: 24px;
  text-align: center;
  font-size: 0.875rem;
  color: var(--muted);
}

.signup a {
  color: var(--terracotta);
  font-size: 1rem;
  font-weight: 500;
}

/* ---------- Success / confirmation ---------- */
.success-hero {
  text-align: center;
  padding: 48px 24px 32px;
}

.success-hero__icon {
  width: 96px;
  height: 96px;
  margin: 0 auto;
  background: rgba(125, 86, 45, 0.1);
  box-shadow: 0 0 15px rgba(125, 86, 45, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.success-hero__title {
  font-family: "Playfair Display", Georgia, serif;
  font-size: clamp(1.75rem, 5vw, 2.25rem);
  font-weight: 600;
  margin-top: 20px;
  color: #1C1B1B;
}

.success-hero__desc {
  max-width: 448px;
  margin: 12px auto 0;
  color: #50453B;
  font-size: 1rem;
  line-height: 1.6;
}

.details-grid {
  max-width: 704px;
  margin: 0 auto 48px;
  padding: 48px;
  background: var(--success-bg);
  border: 1px solid rgba(212, 196, 183, 0.3);
  border-radius: 12px;
}

.details-grid__row {
  padding-bottom: 8px;
  border-bottom: 1px solid rgba(130, 117, 106, 0.2);
}

.details-grid__row + .details-grid__row { margin-top: 16px; }

.details-grid__value {
  font-size: 1.125rem;
  color: #1C1B1B;
  margin-top: 4px;
}

.details-grid__value--accent {
  color: var(--brown);
  font-weight: 700;
}

.action-buttons {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 24px;
  padding: 0 24px 64px;
}

/* ---------- Order review ---------- */
.review-title {
  font-family: "Playfair Display", Georgia, serif;
  font-size: clamp(1.75rem, 4vw, 2.25rem);
  font-weight: 600;
  color: #1C1B1B;
  margin-bottom: 32px;
}

.review-section {
  background: var(--success-bg);
  border: 1px solid rgba(212, 196, 183, 0.3);
  border-radius: var(--radius-md);
  padding: 24px;
  margin-bottom: 16px;
}

.review-section__head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.review-section__label {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.75rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--brown);
}

.review-section__change {
  font-size: 0.75rem;
  color: #82756A;
  text-decoration: underline;
  cursor: pointer;
}

.review-section__name {
  font-size: 1rem;
  font-weight: 700;
}

.review-section__text {
  font-size: 0.875rem;
  color: #50453B;
  line-height: 1.5;
}

.product-item {
  display: flex;
  gap: 24px;
  padding: 24px 0;
  border-top: 1px solid rgba(212, 196, 183, 0.2);
  border-bottom: 1px solid rgba(212, 196, 183, 0.2);
}

.product-item__img {
  width: 96px;
  height: 128px;
  background: #F1EDEC;
  border-radius: var(--radius-sm);
  overflow: hidden;
  flex-shrink: 0;
}

.product-item__img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.product-item__name {
  font-size: 1.125rem;
  font-weight: 700;
}

.product-item__variant {
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: #50453B;
  margin-top: 4px;
}

.product-item__qty {
  font-size: 1rem;
  color: #50453B;
  margin-top: 4px;
}

.product-item__price {
  font-size: 1rem;
  font-weight: 700;
  color: var(--brown);
  margin-top: auto;
}

/* ---------- Payment failed ---------- */
.payment-failed {
  max-width: 672px;
  margin: 48px auto;
  padding: 0 24px 64px;
  text-align: center;
}

.payment-failed__icon {
  width: 80px;
  height: 80px;
  margin: 0 auto;
  background: rgba(212, 24, 61, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.payment-failed__title {
  font-family: "Playfair Display", Georgia, serif;
  font-size: 1.5rem;
  margin-top: 16px;
}

.payment-failed__desc {
  color: var(--text-secondary);
  font-size: 0.875rem;
  margin-top: 8px;
}

.error-box {
  text-align: left;
  margin-top: 32px;
  padding: 24px;
  background: var(--tab-bg);
  border: 1px solid #CCCCCC;
  border-radius: var(--radius-md);
}

.error-box__head {
  display: flex;
  gap: 12px;
  margin-bottom: 16px;
}

.error-box__reasons {
  padding: 12px;
  background: var(--tab-bg);
  border-radius: var(--radius-sm);
  font-size: 0.75rem;
  color: var(--text-body);
}

.error-box__reasons li + li { margin-top: 4px; }

.payment-failed__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 24px;
}

.payment-failed__actions .btn {
  flex: 1;
  min-width: 200px;
  height: 40px;
  padding: 10px 24px;
  background: var(--brown-light);
  color: #fff;
  border-radius: 999px;
  font-size: 1rem;
}

.help-box {
  margin-top: 24px;
  padding: 16px;
  background: #E8C9BE;
  border: 1px solid var(--tab-bg);
  border-radius: var(--radius-md);
  font-size: 0.875rem;
}

.help-box p:last-child {
  font-size: 0.75rem;
  color: var(--text-secondary);
  margin-top: 8px;
}

/* ---------- OTP Modal ---------- */
.otp-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
  padding: 24px;
}

.otp-modal {
  width: min(613px, 100%);
  background: #fff;
  border-radius: 10px;
  border: 1px solid #FBF7F2;
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.15);
  overflow: hidden;
  position: relative;
}

.otp-modal__bg {
  position: absolute;
  inset: 0;
  background: rgba(232, 201, 190, 0.72);
  pointer-events: none;
}

.otp-modal__content {
  position: relative;
  padding: 32px 24px 40px;
  text-align: center;
}

.otp-modal__title {
  font-size: 1rem;
  font-weight: 500;
  text-transform: uppercase;
  margin-bottom: 16px;
}

.otp-modal__desc {
  font-size: 1rem;
  line-height: 1.6;
  margin-bottom: 24px;
  max-width: 420px;
  margin-left: auto;
  margin-right: auto;
}

.otp-inputs {
  display: flex;
  justify-content: center;
  gap: 16px;
  margin-bottom: 24px;
}

.otp-input {
  width: 65px;
  height: 65px;
  text-align: center;
  font-size: 1.5rem;
  font-weight: 600;
  border: none;
  border-radius: var(--radius-sm);
  background: rgba(232, 201, 190, 0.43);
  box-shadow: 0 4px 4px rgba(0, 0, 0, 0.25);
}

.otp-input:focus {
  outline: 2px solid var(--brown);
  background: #fff;
}

.otp-timer {
  font-size: 0.875rem;
  font-weight: 500;
  text-transform: uppercase;
  color: var(--brown-light);
  margin-bottom: 16px;
}

.otp-resend {
  font-size: 0.875rem;
  color: var(--text-secondary);
}

.otp-resend button {
  border: none;
  background: none;
  color: var(--terracotta);
  font-weight: 500;
  cursor: pointer;
  text-decoration: underline;
}

/* ---------- Page shell ---------- */
.page-shell {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

.hidden { display: none !important; }

.tab-panel { display: none; }
.tab-panel.is-active { display: block; }

/* ---------- Responsive ---------- */
@media (max-width: 1024px) {
  .checkout-grid {
    grid-template-columns: 1fr;
  }

  .order-summary {
    position: static;
  }

  .site-footer__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 768px) {
  .site-header__search { display: none; }

  .menu-toggle { display: flex; }

  .site-header__nav {
    display: none;
    flex-direction: column;
    align-items: flex-start;
    padding-bottom: 16px;
  }

  .site-header__nav.is-open { display: flex; }

  .checkout-steps {
    flex-direction: column;
    align-items: flex-start;
  }

  .checkout-step__line { width: 2px; height: 24px; margin-left: 19px; }

  .form-row { grid-template-columns: 1fr; }

  .site-footer__grid { grid-template-columns: 1fr; }

  .login-card {
    position: relative;
    left: auto;
    top: auto;
    transform: none;
    margin: 24px auto;
  }

  body.page-signin {
    overflow: auto;
    padding: 24px 16px;
  }

  .signin-stage {
    width: 100%;
    height: auto;
    min-height: auto;
    padding-bottom: 24px;
  }

  .signin-stage .product { opacity: 0.4; }

  .signin-stage .product--8,
  .signin-stage .product--6,
  .signin-stage .product--5,
  .signin-stage .product--4 { display: none; }

  .details-grid { padding: 24px; }

  .action-buttons { flex-direction: column; align-items: stretch; }

  .action-buttons .btn { width: 100%; }

  .otp-inputs { gap: 8px; }

  .otp-input {
    width: 52px;
    height: 52px;
    font-size: 1.25rem;
  }

  .payment-failed__actions { flex-direction: column; }
}

@media (max-width: 480px) {
  .oauth { flex-direction: column; }

  .btn--facebook,
  .btn--guest { width: 100%; }

  .coupon-row { flex-direction: column; }

  .checkout-actions { flex-direction: column; }

  .checkout-actions .btn { width: 100%; }
}

@media (max-width: 1212px), (max-height: 755px) {
  body.page-signin:not(.page-signin--mobile-stack) .signin-stage {
    transform-origin: top center;
    transform: scale(min(calc((100vw - 24px) / 1172), calc((100vh - 24px) / 715)));
  }
}

@media (max-width: 768px) {
  body.page-signin .signin-stage { transform: none; }
}
